# ===========================================
# MonexUp - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!
# ===========================================

# --- Database (PostgreSQL) ---
# Used by the `postgres` service in docker-compose.yml AND composed into the
# MonexUp API connection string at runtime as:
#   Host=postgres;Port=5432;Database=${DB_NAME};Username=${DB_USER};Password=${DB_PASSWORD}
DB_USER=monexup_user
DB_PASSWORD=
DB_NAME=monexup_db

# --- NAuth (external service) ---
NAUTH_API_URL=http://localhost:5004
NAUTH_JWT_SECRET=
NAUTH_BUCKET=monexup

# --- zTools (external service) ---
ZTOOLS_API_URL=http://localhost:5001

# --- ProxyPay ---
PROXYPAY_API_URL=http://localhost:5100
PROXYPAY_CLIENT_ID=
PROXYPAY_TENANT_ID=monexup
# Used by /Billing/payment-completed HMAC validation. Generate a long random value.
PROXYPAY_WEBHOOK_CALLBACK_SECRET=
# Public URL the customer's browser hits after ProxyPay-hosted payment success
PROXYPAY_COMPLETION_URL_BASE=
# Public URL the customer's browser hits if they cancel the ProxyPay flow
PROXYPAY_RETURN_URL_BASE=

# --- Lofn (Products API) ---
LOFN_API_URL=http://localhost:5003

# --- Dedalo (CMS/Templates API) ---
DEDALO_API_URL=http://localhost:5002

# --- Invite (referrer invite link signing) ---
# HMAC secret used to sign stateless invite links. Use a strong random value in production.
INVITE_SECRET=
