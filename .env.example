# ===========================================
# MonexUp - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control!
# ===========================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=monexup_db
POSTGRES_USER=monexup_user
POSTGRES_PASSWORD=

# --- NAuth ---
NAUTH_DB_NAME=nauth_db
NAUTH_JWT_SECRET=

# --- ProxyPay ---
PROXYPAY_API_URL=http://localhost:5100
PROXYPAY_CLIENT_ID=
PROXYPAY_TENANT_ID=monexup

# --- MailerSend ---
MAILERSEND_API_TOKEN=
MAILERSEND_SENDER=
MAILERSEND_API_URL=https://api.mailersend.com/v1/email

# --- DigitalOcean Spaces (S3-compatible) ---
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=monexup
S3_ENDPOINT=

# --- ChatGPT (used by zTools) ---
CHATGPT_APIURL=https://api.openai.com/v1/chat/completions
CHATGPT_IMAGEAPIURL=https://api.openai.com/v1/images/generations
CHATGPT_APIKEY=
CHATGPT_MODEL=gpt-3.5-turbo

# --- Lofn (Products API) ---
LOFN_API_URL=http://localhost:5003

# --- Frontend (baked at build time) ---
REACT_APP_API_URL=http://localhost:5000
REACT_APP_NAUTH_API_URL=http://localhost:5000
REACT_APP_PROXYPAY_API_URL=http://localhost:5100
REACT_APP_PROXYPAY_CLIENT_ID=
REACT_APP_PROXYPAY_TENANT_ID=monexup
REACT_APP_LOFN_API_URL=http://localhost:5003
REACT_APP_DEDALO_API_URL=http://localhost:5002

# --- zTools API ---
ZTOOLS_API_URL=http://localhost:5001
