# ===========================================
# MonexUp - Production Secrets
# ===========================================
# Copy this file to .env.prod and fill in the values.
# NEVER commit .env.prod to version control!
# ===========================================

MONEXUP_CONNECTION_STRING=Host=<HOST>;Port=<PORT>;Database=<DB>;Username=<USER>;Password=<PASSWORD>
MONEXUP_JWT_SECRET=<STRONG_JWT_SECRET_MIN_64_CHARS>
MONEXUP_INVITE_SECRET=<STRONG_RANDOM_SECRET_openssl_rand_base64_48>

