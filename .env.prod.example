# ===========================================
# MonexUp - Production Secrets
# ===========================================
# Copy this file to .env.prod and fill in the values.
# NEVER commit .env.prod to version control!
# ===========================================

# --- PostgreSQL ---
POSTGRES_USER=<POSTGRES_USER>
POSTGRES_PASSWORD=<STRONG_PASSWORD>
POSTGRES_DB=monexup_db

# --- NAuth ---
NAUTH_DB_NAME=nauth_db
NAUTH_JWT_SECRET=<STRONG_JWT_SECRET_MIN_64_CHARS>

# --- ProxyPay ---
PROXYPAY_API_URL=<PROXYPAY_API_URL>
PROXYPAY_CLIENT_ID=<PROXYPAY_CLIENT_ID>
PROXYPAY_TENANT_ID=monexup

# --- Lofn (Products API) ---
LOFN_API_URL=<LOFN_API_URL>

# --- Dedalo (CMS/Templates API) ---
DEDALO_API_URL=<DEDALO_API_URL>

# --- MailerSend ---
MAILERSEND_API_TOKEN=<MAILERSEND_API_TOKEN>
MAILERSEND_SENDER=<MAILERSEND_SENDER_EMAIL>
MAILERSEND_API_URL=https://api.mailersend.com/v1/email

# --- DigitalOcean Spaces (S3-compatible) ---
S3_ACCESS_KEY=<S3_ACCESS_KEY>
S3_SECRET_KEY=<S3_SECRET_KEY>
NAUTH_BUCKET=monexup
S3_ENDPOINT=<S3_ENDPOINT_URL>

# --- ChatGPT (used by zTools) ---
CHATGPT_APIURL=https://api.openai.com/v1/chat/completions
CHATGPT_IMAGEAPIURL=https://api.openai.com/v1/images/generations
CHATGPT_APIKEY=<CHATGPT_API_KEY>
CHATGPT_MODEL=gpt-3.5-turbo

