# =============================================================================
# MonexUp Frontend — example environment file
# =============================================================================
#
# Two naming styles are accepted during the CRA → Vite migration:
#   - REACT_APP_*  : LEGACY (keep for now). Existing source reads these via
#                    `process.env.REACT_APP_*`; Vite replaces them at build time.
#   - VITE_*       : NEW. New code should read `import.meta.env.VITE_*` instead.
#                    A VITE_FOO key is also auto-aliased to REACT_APP_FOO so
#                    legacy reads keep working until the rename is complete.
#
# Until the rename is finished, prefer to set BOTH for the same value.
# Plan: a follow-up PR will sweep `process.env.REACT_APP_*` → `import.meta.env.VITE_*`
# and drop the REACT_APP_* names.
#
# Copy this file to `.env` (gitignored) for local dev.
# =============================================================================

# --- Build / runtime mode -----------------------------------------------------
NODE_ENV=development
PUBLIC_URL=/
REACT_APP_PRODUCTION=0
REACT_APP_SITE_BASENAME=/
REACT_APP_PROJECT_NAME=MonexUp.com
REACT_APP_WEBSITE_NAME=MonexUp - Digital Marketing and Profesional MMN

# --- Tenant -------------------------------------------------------------------
# Sent as X-Tenant-Id header on every backend request (MonexUp API, NAuth, Lofn, Dedalo).
REACT_APP_TENANT_ID=monexup

# --- API endpoints ------------------------------------------------------------
REACT_APP_API_URL=http://localhost:5000
REACT_APP_NAUTH_API_URL=http://localhost:5004

# Lofn (products / e-commerce) — external service
REACT_APP_LOFN_API_URL=
# VITE_LOFN_API_URL=

# Dedalo (CMS templates) — external service
REACT_APP_DEDALO_API_URL=
# VITE_DEDALO_API_URL=

# --- ProxyPay (PIX) -----------------------------------------------------------
REACT_APP_PROXYPAY_API_URL=
REACT_APP_PROXYPAY_CLIENT_ID=
REACT_APP_PROXYPAY_TENANT_ID=monexup

# --- Stripe (legacy reference; current build prefers ProxyPay) ----------------
REACT_APP_STRIPE_PUBLISHABLE_KEY=
